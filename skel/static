#!/usr/bin/env python3
import sys
import multiprocessing
import webbrowser
import subprocess
import time
from argparse import ArgumentParser, Namespace
from static_lib.stutils import print_shutdown, exists, is_empty
from builder import site_build, ensure_dirs
from static_lib import registry
from static_lib.server import ADDRESS, PORT, serve, print_server

# ----------------------------------------------------------------------
# Build command (unchanged)
def build_site():
    print("Checking directories...")
    error = ensure_dirs()
    if error:
        print("Please, set up your files before building the site!")
        return
    else:
        success = site_build()
        if success:
            print("Site built successfully, check the 'dist' folder")
        else:
            print("There were some errors...")

# ----------------------------------------------------------------------
# Interactive server (manual rebuilds, no auto-reload)
def interactive_server():
    _server_daemon = multiprocessing.Process(
        target=serve,
        args=[False],  # auto_reload=False → no script injection
        name="static_server",
        daemon=True
    )
    try:
        _server_daemon.start()
        print_server(ADDRESS, PORT)

        if not exists("dist") or is_empty("dist"):
            print("No dist found. Building...")
            subprocess.call(["python3", "builder.py"])

        webbrowser.open_new_tab(f"http://{ADDRESS}:{PORT}")

        print('''
            \rEntering interactive console mode
            \r--------------------
            \rCommands:
            \rrebuild - Rebuild the site (then refresh the browser manually).
            \rstatus  - Show server process status.
            \rbrowser - Reopen the browser tab.
            \rexit    - Shutdown the session.
        ''')

        while True:
            cli = input("[DEBUG⚡] > ").strip().lower()
            match cli:
                case 'rebuild':
                    print("Rebuilding...")
                    subprocess.call(["python3", "builder.py"])
                case 'browser':
                    webbrowser.open_new_tab(f"http://{ADDRESS}:{PORT}")
                case 'exit':
                    _server_daemon.terminate()
                    while _server_daemon.is_alive():
                        print_shutdown()
                    print("\n")
                    sys.exit(0)
                case 'status':
                    print(f'''Process {_server_daemon.name}:
                        \rIs alive: {_server_daemon.is_alive()}.
                        \rIs daemon: {_server_daemon.daemon}.
                        \rPID: {_server_daemon.pid}.
                    ''')
                case _:
                    print(f"Unknown command: {cli}")
    except KeyboardInterrupt:
        _server_daemon.terminate()
        print("\n")
        while _server_daemon.is_alive():
            print_shutdown()
        print("\n")
        sys.exit(0)

# ----------------------------------------------------------------------
# Auto-reload server (default for 'run')
def auto_reload_server():
    # Build once if dist is missing/empty
    if not exists("dist") or is_empty("dist"):
        print("No dist found. Building site...")
        site_build()
    webbrowser.open_new_tab(f"http://{ADDRESS}:{PORT}")
    serve(auto_reload=True)  # starts watcher thread and injecting handler

# ----------------------------------------------------------------------
# CLI
if __name__ == "__main__":
    parser = ArgumentParser(
        prog="Static",
        usage="static <command> [options]",
        description="Static site generator"
    )
    parser.add_argument(
        "command",
        choices=["check", "build", "run"],
        help="Command to execute"
    )
    parser.add_argument(
        '-i', '--interactive',
        action='store_true',
        help="Run in interactive mode (manual rebuilds). Only with 'run'."
    )

    args = parser.parse_args()

    match args.command:
        case "build":
            build_site()
        case "check":
            ensure_dirs()
            print("Check done")
        case "run":
            if args.interactive:
                interactive_server()
            else:
                auto_reload_server()   # default: auto-reload